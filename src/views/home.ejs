<%- include('includes/header') %>

<link rel="stylesheet" type="text/css" href="/css/home.css" />
<script src="https://cdnjs.cloudflare.com/ajax/libs/animejs/3.2.1/anime.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>

<body>
  <div class="home-container">

    <!-- ── NAVIGATION ── -->
    <div class="navigation-menu">
      <ul class="nav justify-content-between px-4" style="height:72px; align-items:center;">

        <!-- Brand -->
        <li class="nav-item">
          <a class="nav-brand" href="/admin">
            <div class="nav-brand-icon">☽</div>
            <span class="nav-brand-name">KERVAN</span>
          </a>
        </li>

        <!-- Links -->
        <div class="d-flex" style="gap:4px; align-items:center;">
          <li class="nav-item">
            <a class="nav-link active" href="/admin">Home</a>
          </li>
          <% if (!member) { %>
          <li class="nav-item">
            <a class="nav-link" href="/admin/signup">Signup</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/login">Login</a>
          </li>
          <% } else { %>
          <li class="nav-item">
            <a class="nav-link" href="/admin/product/all">Menu</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/user/all">Users</a>
          </li>
          <li class="nav-item">
            <a class="nav-link" href="/admin/branch/all">Branches</a>
          </li>
          <li class="nav-item nav-logout"
              onclick="return confirm('Do you want to logout?')">
            <a class="nav-link" href="/admin/logout">Logout</a>
          </li>
          <% } %>
        </div>

      </ul>
    </div>
    <!-- /NAVIGATION -->

    <!-- ════════════════════════════════ -->
    <!-- LOGGED-OUT: Landing + Sphere     -->
    <!-- ════════════════════════════════ -->
    <% if (!member) { %>

    <div class="animation-frame">
      <!-- Title -->
      <h1 class="landing-title">KERVAN</h1>

      <div class="landing-divider">
        <div class="landing-divider-line"></div>
        <span class="landing-sub">Premium Restaurant Management</span>
        <div class="landing-divider-line"></div>
      </div>

      <!-- Buttons -->
      <div class="landing-btns">
        <a href="/admin/login"  class="btn-orange">Login</a>
        <a href="/admin/signup" class="btn-ghost">Signup</a>
      </div>

      <!-- Moon animation -->
      <div class="animation-wrapper">☽</div>
    </div>

    <script type="text/javascript" src="/js/home.js"></script>

    <!-- ════════════════════════════════ -->
    <!-- LOGGED-IN: Dashboard             -->
    <!-- ════════════════════════════════ -->
    <% } else { %>

    <div class="dashboard-frame">

      <!-- Welcome bar -->
      <div class="welcome-bar">
        <div>
          <h2>Welcome back, <%= member.memberNick %> 👋</h2>
          <p>Here's what's happening across Kervan branches today.</p>
        </div>
        <div class="welcome-badge">
          ✦ Restaurant Admin
        </div>
      </div>

      <!-- Stats grid -->
      <div class="stats-grid">

        <div class="stat-card">
          <div class="stat-card-icon"
               style="background:rgba(255,107,0,0.1); color:#ff6b00;">
            🧾
          </div>
          <div class="stat-label">Total Orders</div>
          <div class="stat-value" id="stat-orders">
            <span class="k-skeleton"></span>
          </div>
          <div class="stat-sub">All time</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon"
               style="background:rgba(76,175,130,0.1); color:#4caf82;">
            🍽️
          </div>
          <div class="stat-label">Total Products</div>
          <div class="stat-value" id="stat-products">
            <span class="k-skeleton"></span>
          </div>
          <div class="stat-sub">In catalog</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon"
               style="background:rgba(156,202,255,0.1); color:#9ccaff;">
            👤
          </div>
          <div class="stat-label">Total Users</div>
          <div class="stat-value" id="stat-users">
            <span class="k-skeleton"></span>
          </div>
          <div class="stat-sub">Registered</div>
        </div>

        <div class="stat-card">
          <div class="stat-card-icon"
               style="background:rgba(227,194,133,0.1); color:#e3c285;">
            ✓
          </div>
          <div class="stat-label">Active Users</div>
          <div class="stat-value" id="stat-active">
            <span class="k-skeleton"></span>
          </div>
          <div class="stat-sub">Status: active</div>
        </div>

      </div>
      <!-- /stats-grid -->

      <!-- Quick links -->
      <div class="quick-links">
        <a href="/admin/product/all" class="quick-link-card">
          <div class="quick-link-icon"
               style="background:rgba(255,107,0,0.1); color:#ff6b00;">
            🍽️
          </div>
          <div>
            <div class="quick-link-title">Manage Menu</div>
            <div class="quick-link-sub">Add & edit products</div>
          </div>
        </a>

        <a href="/admin/user/all" class="quick-link-card">
          <div class="quick-link-icon"
               style="background:rgba(76,175,130,0.1); color:#4caf82;">
            👥
          </div>
          <div>
            <div class="quick-link-title">Manage Users</div>
            <div class="quick-link-sub">View & moderate members</div>
          </div>
        </a>

        <a href="/admin/branch/all" class="quick-link-card">
          <div class="quick-link-icon"
               style="background:rgba(156,202,255,0.1); color:#9ccaff;">
            📍
          </div>
          <div>
            <div class="quick-link-title">Manage Branches</div>
            <div class="quick-link-sub">Itaewon · COEX · Famille</div>
          </div>
        </a>
      </div>
      <!-- /quick-links -->

    </div>
    <!-- /dashboard-frame -->

    <script>
      // AJAX stats — /admin/dashboard/stats
      $(function () {
        axios.get('/admin/dashboard/stats')
          .then(function (res) {
            var d = res.data;
            $('#stat-orders').text(d.totalOrders.toLocaleString());
            $('#stat-products').text(d.totalProducts.toLocaleString());
            $('#stat-users').text(d.totalUsers.toLocaleString());
            $('#stat-active').text(d.activeUsers.toLocaleString());
          })
          .catch(function () {
            ['stat-orders','stat-products','stat-users','stat-active']
              .forEach(function (id) { $('#' + id).text('—'); });
          });
      });
    </script>

    <div class="animation-wrapper">☽</div>

    <% } %>

  </div>
  <!-- /home-container -->
</body>

<%- include('includes/footer') %>
